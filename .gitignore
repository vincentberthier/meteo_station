# Generated by Cargo
# will have compiled files and executables
debug/
target/

# meteo-web runtime SQLite database (created on first run; not source)
meteo.db
meteo.db-shm
meteo.db-wal

# These are backup files generated by rustfmt
**/*.rs.bk

# MSVC Windows builds of rustc generate these, which store debugging information
*.pdb

# KiCad local/transient files (UI state + generated ERC reports)
*.kicad_prl
*-erc.rpt
# KiCad runtime cruft — lock files (held while the GUI is open) and autosaves
*.lck
_autosave-*
*.kicad_*-bak
fp-info-cache
